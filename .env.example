# Yoga Kailasa — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Django Core ──────────────────────────────────────────────────────────────

# Generate a strong key with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY='your-secret-key-here'

# Set to 'true' for development, 'false' for production
DEBUG='false'

# Comma-separated list of allowed hostnames
# Example: ALLOWED_HOSTS='yogakailasa.com,www.yogakailasa.com'
ALLOWED_HOSTS='localhost,127.0.0.1'

# Additional CSRF trusted origins beyond localhost (comma-separated)
# Example: EXTRA_CSRF_TRUSTED_ORIGINS='https://yogakailasa.com,https://www.yogakailasa.com'
EXTRA_CSRF_TRUSTED_ORIGINS=''

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────

POSTGRES_DB='yoga_kailasa_db'
POSTGRES_USER='your_database_user'
POSTGRES_PASSWORD='your_database_password'
POSTGRES_HOST='localhost'
POSTGRES_PORT='5432'

# ─── Redis & Celery ───────────────────────────────────────────────────────────

REDIS_URL='redis://localhost:6379/0'

# ─── Email ────────────────────────────────────────────────────────────────────

# Development default (prints to console):
# EMAIL_BACKEND='django.core.mail.backends.console.EmailBackend'
#
# Production (SMTP):
EMAIL_BACKEND='django.core.mail.backends.console.EmailBackend'
EMAIL_HOST='smtp.gmail.com'
EMAIL_PORT='587'
EMAIL_USE_TLS='true'
EMAIL_HOST_USER='your_email@example.com'
EMAIL_HOST_PASSWORD='your_email_app_password'
DEFAULT_FROM_EMAIL='no-reply@yogakailasa.com'

# ─── Paystack Payments ────────────────────────────────────────────────────────

# Get keys from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY='sk_test_your_secret_key'
PAYSTACK_PUBLIC_KEY='pk_test_your_public_key'
PAYSTACK_WEBHOOK_URL='https://yourdomain.com/payments/webhook/paystack/'

# ─── Security (Production only) ───────────────────────────────────────────────

SECURE_SSL_REDIRECT='true'
SESSION_COOKIE_SECURE='true'
CSRF_COOKIE_SECURE='true'

# ─── CDN (Optional) ───────────────────────────────────────────────────────────

# CDN_URL='https://cdn.yourdomain.com/'
CDN_URL=''

# ─── Site ─────────────────────────────────────────────────────────────────────

# Used in email links — set to your production domain
SITE_URL='https://yogakailasa.com'
